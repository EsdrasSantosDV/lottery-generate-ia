# Copie para `.env` e preencha (valores do Dashboard Supabase / CLI).

VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_ANON_KEY=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# CUIDADO: se definir, desativa o atalho "já está atualizado" e o worker refaz fetch desde N.
# Use só temporariamente p/ backfill de premiação; comente ou apague depois.
# VITE_CAIXA_BACKFILL_FROM_CONCURSO=

# Se a API da Caixa devolver 403/429, aumente os intervalos (ms; defaults ~1300–1400 no código).
# VITE_CAIXA_REQUEST_DELAY_MS=2000
# VITE_CAIXA_MAIN_GAP_MS=2000

# Desliga o sync ao carregar a página: não chama a API da Caixa nem grava sorteios no Supabase (útil p/ dev de features).
# VITE_CAIXA_SYNC_DISABLED=1
